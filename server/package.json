{
  "name": "pingloop-server",
  "private": true,
  "type": "module",
  "description": "Cloudflare Worker that sends PingLoop background push notifications.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "migrate:local": "wrangler d1 migrations apply pingloop --local",
    "migrate:remote": "wrangler d1 migrations apply pingloop --remote"
  },
  "dependencies": {
    "@block65/webcrypto-web-push": "^1.0.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "wrangler": "^3.114.1"
  }
}
