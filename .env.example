# Optional background push backend. Leave both unset for a foreground-only
# timer (the default GitHub Pages experience). Set them to enable alerts that
# arrive with the app closed. Neither value is secret.

# Base URL of your deployed Cloudflare Worker, no trailing slash.
VITE_PUSH_API=https://pingloop.your-subdomain.workers.dev

# VAPID public key. Must match the Worker's VAPID_PUBLIC_KEY.
VITE_VAPID_PUBLIC_KEY=
